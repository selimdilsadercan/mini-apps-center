# Copy to keystore.properties and fill in your values.
# keystore.properties is gitignored — do not commit passwords.
#
# Generate a new keystore:
# keytool -genkeypair -v -storetype PKCS12 -keystore everything-release.jks -alias everything -keyalg RSA -keysize 2048 -validity 10000
#
storeFile=everything-release.jks
storePassword=YOUR_STORE_PASSWORD
keyAlias=everything
keyPassword=YOUR_KEY_PASSWORD
