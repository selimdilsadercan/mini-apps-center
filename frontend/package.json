{
  "name": "@recipe/frontend",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "generate": "npx tsx scripts/generate-types.ts",
    "ios": "next build && npx cap sync && npx cap open ios",
    "increment-version": "npx tsx scripts/increment-version.ts",
    "mobile": "next build && npm run sync && npm run apk && npm run open-apk",
    "sync": "cmd /c \"set CI=1 && npx cap sync\"",
    "store": "npm run increment-version && next build && npm run sync && npm run apk && npm run open-aab",
    "apk": "cd android && cmd /c gradlew.bat assembleDebug && cmd /c gradlew.bat bundleRelease",
    "open-apk": "explorer android\\app\\build\\outputs\\apk\\debug",
    "aab": "npm run increment-version && cd android && cmd /c gradlew.bat bundleRelease",
    "open-aab": "explorer android\\app\\build\\outputs\\bundle\\release",
    "clean": "cd android && cmd /c gradlew.bat clean"
  },
  "dependencies": {
    "@ai-sdk/openai": "^3.0.53",
    "@capacitor-firebase/messaging": "^8.2.0",
