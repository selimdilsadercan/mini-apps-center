{
	"id":   "mini-apps-center-8u7i",
	"lang": "typescript",
	"global_cors": {
		"allow_origins_with_credentials": [
			"http://localhost:3000",
			"http://localhost:4000",
			"http://my.localhost:3000",
			"http://my.localhost:4000",
			"http://127.0.0.1:3000",
			"http://127.0.0.1:4000",
			"https://allminiapps.com",
			"https://my.allminiapps.com",
			"capacitor://localhost",
			"ionic://localhost",
			"https://localhost",
			"http://localhost"
		],
		"allow_headers": ["Authorization", "Content-Type", "X-App-Version"],
		"expose_headers": ["*"]
	}
}
