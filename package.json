{
  "name": "recipe-monorepo",
  "version": "1.0.0",
  "private": true,
  "packageManager": "bun@1.1.38",
  "workspaces": [
    "frontend",
    "backend"
  ],
  "scripts": {
    "dev": "bun x concurrently -n frontend,encore -c blue,green \"npm:frontend\" \"npm:encore\"",
    "frontend": "cd frontend && npm run dev",
    "generate": "cd backend && npm run generate",
    "encore": "cd backend && encore run",
    "clean": "cd frontend && npm run clean",
    "mobile": "cd frontend && npm run mobile",
    "store": "cd frontend && npm run store"
  }
}
